{
  "grammars": [
    {
      "name": "http-rest",
      "camelcase": "HttpRest",
      "scope": "source.http",
      "path": ".",
      "file-types": [
        "http",
        "rest"
      ],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for HTTP request files (.http, .rest)",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-http-rest"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
