{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "http",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "request"
          },
          {
            "type": "SYMBOL",
            "name": "request_separator"
          },
          {
            "type": "SYMBOL",
            "name": "file_variable"
          },
          {
            "type": "SYMBOL",
            "name": "comment"
          },
          {
            "type": "SYMBOL",
            "name": "_blank_line"
          }
        ]
      }
    },
    "request_separator": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "###"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[ \\t]+"
                },
                {
                  "type": "FIELD",
                  "name": "label",
                  "content": {
                    "type": "SYMBOL",
                    "name": "separator_label"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "separator_label": {
      "type": "PATTERN",
      "value": "[^\\r\\n]+"
    },
    "request": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "annotation"
            }
          },
          {
            "type": "SYMBOL",
            "name": "request_line"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "header"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "body"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "annotation": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "#"
            },
            {
              "type": "STRING",
              "value": "//"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "STRING",
          "value": "@"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "annotation_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[ \\t]+"
                },
                {
                  "type": "FIELD",
                  "name": "value",
                  "content": {
                    "type": "SYMBOL",
                    "name": "annotation_value"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "annotation_name": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "name"
        },
        {
          "type": "STRING",
          "value": "prompt"
        },
        {
          "type": "STRING",
          "value": "note"
        },
        {
          "type": "STRING",
          "value": "no-redirect"
        },
        {
          "type": "STRING",
          "value": "no-cookie-jar"
        }
      ]
    },
    "annotation_value": {
      "type": "PATTERN",
      "value": "[^\\r\\n]+"
    },
    "request_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "method",
          "content": {
            "type": "SYMBOL",
            "name": "method"
          }
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]+"
        },
        {
          "type": "FIELD",
          "name": "url",
          "content": {
            "type": "SYMBOL",
            "name": "url"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[ \\t]+"
                },
                {
                  "type": "FIELD",
                  "name": "version",
                  "content": {
                    "type": "SYMBOL",
                    "name": "http_version"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "method": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "GET"
        },
        {
          "type": "STRING",
          "value": "POST"
        },
        {
          "type": "STRING",
          "value": "PUT"
        },
        {
          "type": "STRING",
          "value": "DELETE"
        },
        {
          "type": "STRING",
          "value": "PATCH"
        },
        {
          "type": "STRING",
          "value": "HEAD"
        },
        {
          "type": "STRING",
          "value": "OPTIONS"
        },
        {
          "type": "STRING",
          "value": "CONNECT"
        },
        {
          "type": "STRING",
          "value": "TRACE"
        }
      ]
    },
    "url": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "variable"
          },
          {
            "type": "SYMBOL",
            "name": "url_segment"
          }
        ]
      }
    },
    "url_segment": {
      "type": "PATTERN",
      "value": "[^\\s{}]+"
    },
    "http_version": {
      "type": "PATTERN",
      "value": "HTTP\\/[0-9.]+"
    },
    "header": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "header_name"
          }
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[ \\t]*"
                },
                {
                  "type": "FIELD",
                  "name": "value",
                  "content": {
                    "type": "SYMBOL",
                    "name": "header_value"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "header_name": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9\\-_]+"
    },
    "header_value": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "variable"
          },
          {
            "type": "SYMBOL",
            "name": "header_value_segment"
          }
        ]
      }
    },
    "header_value_segment": {
      "type": "PATTERN",
      "value": "[^\\r\\n{}]+"
    },
    "body": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_body_separator"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "file_reference"
            },
            {
              "type": "SYMBOL",
              "name": "raw_body"
            }
          ]
        }
      ]
    },
    "file_reference": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "<@"
            },
            {
              "type": "STRING",
              "value": "<"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "FIELD",
          "name": "path",
          "content": {
            "type": "SYMBOL",
            "name": "file_path"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "file_path": {
      "type": "PATTERN",
      "value": "[^\\r\\n]+"
    },
    "raw_body": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "body_line"
            },
            {
              "type": "SYMBOL",
              "name": "_blank_line"
            }
          ]
        }
      }
    },
    "body_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "body_content"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "variable": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{{"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "system_variable"
            },
            {
              "type": "SYMBOL",
              "name": "variable_name"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "}}"
        }
      ]
    },
    "variable_name": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_.]*"
    },
    "system_variable": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "$"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "system_variable_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[ \\t]+"
                },
                {
                  "type": "FIELD",
                  "name": "args",
                  "content": {
                    "type": "SYMBOL",
                    "name": "system_variable_args"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "system_variable_name": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "guid"
        },
        {
          "type": "STRING",
          "value": "randomInt"
        },
        {
          "type": "STRING",
          "value": "timestamp"
        },
        {
          "type": "STRING",
          "value": "datetime"
        },
        {
          "type": "STRING",
          "value": "localDatetime"
        },
        {
          "type": "STRING",
          "value": "dotenv"
        },
        {
          "type": "STRING",
          "value": "processEnv"
        }
      ]
    },
    "system_variable_args": {
      "type": "PATTERN",
      "value": "[^}]+"
    },
    "file_variable": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "@"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "file_variable_name"
          }
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "file_variable_value"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "file_variable_name": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "file_variable_value": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "variable"
          },
          {
            "type": "SYMBOL",
            "name": "file_variable_raw"
          }
        ]
      }
    },
    "file_variable_raw": {
      "type": "PATTERN",
      "value": "[^\\r\\n{}]+"
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "#"
            },
            {
              "type": "STRING",
              "value": "//"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[ \\t]*"
                },
                {
                  "type": "SYMBOL",
                  "name": "comment_text"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "comment_text": {
      "type": "PATTERN",
      "value": "[^\\r\\n@][^\\r\\n]*"
    },
    "_blank_line": {
      "type": "PATTERN",
      "value": "[ \\t]*\\r?\\n"
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "body_content"
    },
    {
      "type": "SYMBOL",
      "name": "_body_separator"
    }
  ],
  "inline": [],
  "supertypes": []
}
